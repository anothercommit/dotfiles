syntax enable
set termguicolors
set filetype=on
set background=dark
set noshowmode
set number
set relativenumber
set cursorline
set showmatch
set hlsearch
set splitright
set splitbelow
set nowrap
set smartindent
set smarttab
set shiftwidth=4
set expandtab
set tabstop=4

colorscheme sonokai

set completeopt=menu,menuone,noselect
